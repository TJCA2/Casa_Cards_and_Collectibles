# ============================================================
# CASA CARDS & COLLECTIBLES — Environment Variables Reference
# ============================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# All secrets must be strong random strings (min 32 chars).
# ============================================================

# App
NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_SECRET=<generate with: openssl rand -base64 64>
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Database (Supabase PostgreSQL)
# DATABASE_URL → Transaction pooler (port 6543) — used by the app at runtime
#   Append: ?pgbouncer=true&connection_limit=1
DATABASE_URL=<Supabase transaction pooler URL — port 6543>
# DIRECT_URL → Session pooler (port 5432) — used by Prisma CLI (db push, migrate)
DIRECT_URL=<Supabase session pooler URL — port 5432>

# eBay API
EBAY_CLIENT_ID=<eBay App Client ID>
EBAY_CLIENT_SECRET=<eBay App Client Secret>
EBAY_SYNC_SECRET=<generate with: openssl rand -base64 32>
# Vercel Cron — Vercel auto-injects this; set it manually in local dev if needed
CRON_SECRET=<generate with: openssl rand -base64 32>

# Stripe
STRIPE_SECRET_KEY=sk_test_<replace with live key for production>
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_<replace with live key for production>
STRIPE_WEBHOOK_SECRET=whsec_<from Stripe dashboard>

# PayPal
PAYPAL_CLIENT_ID=<PayPal App Client ID>
PAYPAL_CLIENT_SECRET=<PayPal App Client Secret>

# Email (Resend)
RESEND_API_KEY=re_<from Resend dashboard>
EMAIL_FROM=orders@yourdomain.com

# Image Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=<cloud_name>
CLOUDINARY_API_KEY=<api_key>
CLOUDINARY_API_SECRET=<api_secret>

# Shipping (EasyPost)
EASYPOST_API_KEY=<from EasyPost dashboard>

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Tax (Stripe Tax or TaxJar)
TAXJAR_API_KEY=<from TaxJar dashboard>

# Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=<from Upstash dashboard>
UPSTASH_REDIS_REST_TOKEN=<from Upstash dashboard>

# CAPTCHA (Cloudflare Turnstile) — https://dash.cloudflare.com/
# Test keys (always pass): sitekey=1x00000000000000000000AA secret=1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=<from Cloudflare dashboard>
TURNSTILE_SECRET_KEY=<from Cloudflare dashboard>

# Admin bootstrap — used once to promote the first admin user via POST /api/admin/promote
# Header: X-Admin-Secret: <value>  Body: { "email": "admin@yourdomain.com" }
# Remove or rotate after first use.
ADMIN_BOOTSTRAP_SECRET=<generate with: openssl rand -base64 32>
